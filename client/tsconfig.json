{
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"skipLibCheck": true,

		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",

		/* STRONG TYPING */
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,

		/* ALIASES */
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"],
			"@api/*": ["src/api/*"],
			"@common/*": ["src/common/*"],
			"@components/*": ["src/components/*"],
			"@routes/*": ["src/routes/*"],
			"@types/*": ["src/types/*"],
			"@utils/*": ["src/utils/*"],
			"@pages/*": ["src/pages/*"]
		}
	},
	"include": ["src"]
}
