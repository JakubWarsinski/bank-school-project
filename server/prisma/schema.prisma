generator client {
    provider = "prisma-client"
    moduleFormat = "commonjs"
    output   = "generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum UserRole {
    CLIENT
    ADMIN
    EMPLOYEE
}

model ResetToken {
	@@map("reset_token")

	user_id					Int					@unique
	token_hash				String
	expire_at				DateTime
}

model User {
    @@map("users")

    user_id					Int					@id @default(autoincrement())
    code                    String              @unique(map: "kod klienta") @db.Char(16)
    role                    UserRole            @default(CLIENT)

    first_name              String              @db.VarChar(50)
    last_name               String              @db.VarChar(50)
    date_of_birth			String
    pesel                   String              @unique(map: "pesel") @db.Char(11)
  
    email                   String              @unique(map: "email") @db.VarChar(60)
    phone_number            String              @db.VarChar(11)
  
    street                  String              @db.VarChar(80)
    city                    String              @db.VarChar(80)
    postal_code             String              @db.Char(6)
  
    password_hash           String              @db.VarChar(254)
    is_active               Boolean             @default(true)

	id_card_number    		String?   			@db.VarChar(20)
	id_card_issue     		DateTime?
	id_card_expiry    		DateTime?

	profession        		String?   			@db.VarChar(100)
  	monthly_net_income 		String?  			@db.VarChar(50)
	main_income_sources 	String? 			@db.VarChar(200)
    
    created_at              DateTime            @default(now())
    updated_at              DateTime            @updatedAt

    session                 Session?
    accounts                UserAccount[]
	notifications			Notification[]

    @@index([email, code, pesel])
}


model Session {
    @@map("sessions")

	user_id					Int					@unique
    
	token_hash				String				

    ip_address				String?
    user_agent				String
    device					String?

    expires_at				DateTime
	
	created_at				DateTime			@default(now())
	updated_at              DateTime            @updatedAt

    user                    User                @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

enum AccountStatus {
    ACTIVE
    BLOCKED
    SUSPENDED
    CLOSED
}

model Account {
    @@map("accounts")

    account_id				Int					@id @default(autoincrement())
	iban					String				@unique(map: "iban") @db.Char(28)
    currency				String				@db.Char(3)
    name					String				@db.VarChar(50) @default("Konto osobiste")
    status					AccountStatus		@default(ACTIVE)

    current_balance			Decimal				@default(0.0) @db.Decimal(18,2)
    available_balance		Decimal				@default(0.0) @db.Decimal(18,2)
    blocked_amount			Decimal				@default(0.0) @db.Decimal(18,2)

    daily_transfer_limit	Decimal				@default(0.0) @db.Decimal(18,2)

    closed_at				DateTime?
    closed_reason			String?				@db.VarChar(150)

    created_at				DateTime			@default(now())
    updated_at				DateTime			@updatedAt

    cards                   Card[]
    users                   UserAccount[]
    sent_transactions       Transaction[]       @relation("sender")
    received_transactions   Transaction[]       @relation("receiver")

    @@index([iban])
}

enum AccountRole {
    OWNER
    CO_OWNER
}

model UserAccount {
    @@map("user_accounts")

	user_account_id			Int					@id @default(autoincrement())
    user_id                 Int
    account_id              Int
    
	role                    AccountRole         @default(OWNER)

    user                    User                @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
    account                 Account             @relation(fields: [account_id], references: [account_id], onDelete: Cascade)

    @@unique([account_id, user_id], map: "account_id_user_id")
}

enum StatusType {
    PENDING
    COMPLETED
    FAILED
    CANCELLED
    BLOCKED
    REFUNDED
}

enum TransactionType {
    INTERNAL_TRANSFER
    CARD_PAYMENT
    CARD_WITHDRAWAL
    ADJUSTMENT
    REVERSAL
}

model Transaction {
    @@map("transactions")

    transaction_id          Int					@id @default(autoincrement())
    code                    String              @unique(map: "kod transakcji") @db.Char(30)
    status                  StatusType          @default(PENDING)
	type					TransactionType		@default(INTERNAL_TRANSFER)
    
	sender_id               Int
    receiver_id             Int
    
	title                   String              @db.VarChar(80)
    description             String              @db.VarChar(200)
    amount                  Decimal             @db.Decimal(18, 2)
    currency                String              @db.Char(3) 
    booking_date            DateTime?       
    
	created_at              DateTime            @default(now())
    updated_at              DateTime            @default(now()) @updatedAt

    sender                  Account             @relation(name: "sender", fields: [sender_id], references: [account_id], onDelete: Cascade)
    receiver                Account             @relation(name: "receiver", fields: [receiver_id], references: [account_id], onDelete: Cascade)

    @@index([code, sender_id, receiver_id])
}

enum CardStatus {
    ACTIVE
    BLOCKED_BY_USER
    BLOCKED_BY_BANK
    STOLEN
    LOST
    EXPIRED
    CLOSED
}

model Card {
    @@map("cards")

    card_id                 Int					@id @default(autoincrement())
    account_id              Int
    
	name                    String              @db.VarChar(50) @default("Moja Karta")
	status					CardStatus			@default(ACTIVE)
    
	card_number_hash        String              @db.VarChar(254)
    last_digits             String              @db.Char(4)
    cvv_hash                String              @db.VarChar(254)
    pin_hash                String              @db.VarChar(254)
    expiry_month			Int
    expiry_year				Int
    
	payment_limit			Decimal				@db.Decimal(18,2) @default(5000.0)
    withdraw_limit			Decimal				@db.Decimal(18,2) @default(5000.0)
    daily_payment_limit		Decimal				@db.Decimal(18,2) @default(500.0)
    daily_withdraw_limit	Decimal				@db.Decimal(18,2) @default(500.0)
	
	blocked_at				DateTime?
    blocked_reason			String?				@db.VarChar(150)
    
    created_at              DateTime            @default(now())
    updated_at              DateTime            @default(now()) @updatedAt

    account                 Account             @relation(fields: [account_id], references: [account_id], onDelete: Cascade)
}

enum NotificationType {
    SYSTEM
    SECURITY
    TRANSACTION
    ACCOUNT
    CARD
}

model Notification {
    @@map("notifications")

    notification_id			Int					@id @default(autoincrement())
    user_id					Int
    
	type					NotificationType
    title					String				@db.VarChar(120)
    message					String				@db.Text

    created_at				DateTime			@default(now())

    user					User				@relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}
