{
	"moduleFileExtensions": ["js", "json", "ts"],
	"rootDir": "..",
	"testEnvironment": "node",
	"moduleNameMapper": {
		"^@/(.*)$": "<rootDir>/src/$1"
	},
	"setupFilesAfterEnv": ["<rootDir>/test/setup/e2e.setup.ts"],
	"transformIgnorePatterns": ["node_modules/(?!@prisma/client)"],
	"transform": {
		"^.+\\.(t|j)s$": "ts-jest"
	},
	"testMatch": ["<rootDir>/test/e2e/**/*.e2e-spec.ts"]
}
