{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2023",
		"outDir": "./dist",
		"sourceMap": true,
		"strict": true,
		"moduleResolution": "node16",
		"esModuleInterop": true,
		"paths": {
			"@/*": ["./src/*"],
			"@common/*": ["./src/common/*"],
			"@config/*": ["./src/config/*"],
			"@modules/*": ["./src/modules/*"],
			"@db/*": ["./prisma/*"],
			"@prisma/*": ["./src/prisma/*"]
		},
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true
	}
}
