{
	"compilerOptions": {
		"module": "commonjs",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"allowJs": true,
		"declaration": true,
		"removeComments": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"target": "ES2023",
		"sourceMap": true,
		"outDir": "./dist",
		"paths": {
			"@/*": ["./src/*"],
			"@common/*": ["./src/common/*"],
			"@config/*": ["./src/config/*"],
			"@modules/*": ["./src/modules/*"],
			"@db/*": ["./prisma/*"],
			"@prisma/*": ["./src/prisma/*"]
		},
		"incremental": true,
		"skipLibCheck": true,
		"strictNullChecks": true,
		"forceConsistentCasingInFileNames": true
	}
}
